# Sponsor Engine optional integrations.
# Do not put real credentials in this file.

# Existing host/admin access
TOURNAMENT_HOST_ACCOUNT_EMAILS=
TOURNAMENT_HOST_ACCOUNT_IDS=
TOURNAMENT_ADMIN_TOKEN=

# Netlify Blobs fallback for local/server contexts
BLOBS_SITE_ID=
BLOBS_TOKEN=

# Sponsor Engine feature flags
SPONSOR_ENGINE_ENABLED=false
SPONSOR_SENDING_ENABLED=false
SPONSOR_MAX_NEW_MESSAGES_PER_DAY=10
SPONSOR_MAX_FOLLOW_UPS_PER_DAY=10
SPONSOR_MIN_DELAY_BETWEEN_MESSAGES_MINUTES=30
SPONSOR_MAX_CONTACTS_PER_COMPANY=1
SPONSOR_ALLOWED_WEEKDAYS=1,2,3,4,5
SPONSOR_QUIET_HOURS_START=18:00
SPONSOR_QUIET_HOURS_END=09:00

# Optional future providers
SPONSOR_SEARCH_PROVIDER=mock
SPONSOR_SEARCH_API_KEY=
SPONSOR_AI_PROVIDER=mock
SPONSOR_AI_API_KEY=
SPONSOR_EMAIL_PROVIDER=mock
SPONSOR_EMAIL_API_KEY=
SPONSOR_EMAIL_FROM=
SPONSOR_CALENDAR_PROVIDER=mock
SPONSOR_CALENDAR_API_KEY=
SPONSOR_STORAGE_PROVIDER=netlify-blobs
SPONSOR_ANALYTICS_PROVIDER=mock
